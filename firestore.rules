rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es el administrador
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@jomstudio.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin')
      );
    }

    // Reglas para la colección de usuarios (Perfil)
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para la colección 'products'
    match /products/{document=**} {
      // Cualquier persona puede leer el catálogo de productos
      allow read: if true;
      // Solo el administrador puede crear, actualizar o borrar productos
      allow write: if isAdmin();
    }
    
    // Reglas para la configuración (BCV Automático)
    match /configuracion/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reglas para la colección 'settings' (legacy)
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reglas para tipografías
    match /typographies/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && request.resource.data.userId == request.auth.uid);
    }

    // Reglas para la colección 'orders'
    match /orders/{document=**} {
      allow read: if isAdmin();
      // Permitir crear órdenes solo si el subtotal y la tasa bcv existen (como mínimo para evitar inyección de basura)
      allow create: if request.resource.data.keys().hasAll(['customerInfo', 'items', 'subtotalBase', 'totalVes']) 
                    && request.resource.data.items is list;
      allow update, delete: if isAdmin();
    }

    // Denegar el acceso a cualquier otra colección por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
