rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es el administrador principal
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@jomstudio.com';
    }

    // Reglas para la colección 'products'
    match /products/{document=**} {
      // Cualquier persona puede leer el catálogo de productos
      allow read: if true;
      // Solo el administrador puede crear, actualizar o borrar productos
      allow write: if isAdmin();
    }
    
    // Reglas para la colección 'settings' (ej: tasas BCV)
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reglas para la colección 'orders' (si la hubiera)
    match /orders/{document=**} {
      // Solo el admin puede leer todas las órdenes, o el usuario que la creó
      allow read: if isAdmin();
      // Permitir que cualquiera (incluso sin login) cree una orden si viene del carrito, 
      // pero solo el admin puede editarlas o borrarlas
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Denegar el acceso a cualquier otra colección por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
